<% content_for :title, "Sign In · Iron Control" %>

<% input = "w-full rounded border border-ink-600 bg-ink-850/60 px-3 py-2 text-sm text-zinc-100 placeholder-zinc-600 focus:border-iron-500/60 focus:outline-none focus:ring-1 focus:ring-iron-500/40" %>
<% label = "mb-1 block text-xs font-semibold uppercase tracking-wider text-zinc-500" %>

<div class="mb-8 text-center">
  <h1 class="text-2xl font-bold text-zinc-100">iron-<span class="text-iron-500">control</span></h1>
  <p class="mt-1 text-sm text-zinc-500">Operator console sign in.</p>
</div>

<div class="rounded-xl border border-ink-600 bg-ink-850/60 p-6">
  <% if flash[:alert] %>
    <div class="mb-6 rounded border border-red-500/40 bg-red-500/[0.08] px-4 py-3 text-sm text-red-300"><%= flash[:alert] %></div>
  <% end %>

  <%= form_with url: login_path, method: :post do |f| %>
    <div class="space-y-5">
      <div>
        <%= f.label :email, class: label %>
        <%= f.email_field :email, class: input, placeholder: "you@example.com", autocomplete: "username", autofocus: true %>
      </div>
      <div>
        <%= f.label :password, class: label %>
        <%= f.password_field :password, class: input, autocomplete: "current-password" %>
      </div>
    </div>

    <div class="mt-6">
      <%= f.submit "Sign in", class: "w-full cursor-pointer rounded border border-iron-500/40 bg-iron-500/10 px-4 py-2 text-sm text-iron-300 transition-colors hover:bg-iron-500/20 hover:text-iron-200" %>
    </div>
  <% end %>
</div>
