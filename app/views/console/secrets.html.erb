<% content_for :title, "Secrets · Iron Control" %>

<% total = @secrets_by_kind.values.sum(&:size) %>

<div class="mb-8">
  <h1 class="text-2xl font-bold text-zinc-100">Secrets</h1>
  <p class="mt-1 text-sm text-zinc-500"><%= pluralize(total, "secret") %> across <%= @secrets_by_kind.size %> kinds.</p>
</div>

<div class="space-y-10">
  <% @secrets_by_kind.each do |kind, records| %>
    <section>
      <div class="mb-3 flex items-center gap-3">
        <h2 class="text-sm font-semibold text-zinc-200"><%= secret_kind_label(kind) %></h2>
        <span class="rounded-full bg-ink-700 px-2 py-0.5 text-xs text-zinc-400"><%= records.size %></span>
      </div>

      <% if records.empty? %>
        <p class="rounded-lg border border-dashed border-ink-600 bg-ink-850/40 px-5 py-6 text-sm text-zinc-600">No <%= secret_kind_label(kind).downcase %> secrets.</p>
      <% else %>
        <div class="overflow-hidden rounded-xl border border-ink-600 bg-ink-850/60">
          <table class="min-w-full divide-y divide-ink-600 text-sm">
            <thead class="bg-ink-800/80 text-left text-xs uppercase tracking-wider text-zinc-500">
              <tr>
                <th class="px-5 py-3 font-medium">ID</th>
                <th class="px-5 py-3 font-medium">Foreign ID</th>
                <th class="px-5 py-3 font-medium">Name</th>
                <th class="px-5 py-3 font-medium">Source</th>
                <th class="px-5 py-3 font-medium">Injects Into</th>
                <th class="px-5 py-3 font-medium">Namespace</th>
                <th class="px-5 py-3 font-medium">Labels</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-ink-700">
              <% records.each do |s| %>
                <tr class="transition-colors hover:bg-iron-500/[0.06]">
                  <td class="px-5 py-3 whitespace-nowrap text-iron-400"><%= s.oid %></td>
                  <td class="px-5 py-3 whitespace-nowrap text-zinc-300"><%= s.foreign_id || "—" %></td>
                  <td class="px-5 py-3 whitespace-nowrap text-zinc-100"><%= s.try(:name).presence || %(<span class="text-zinc-600">unnamed</span>).html_safe %></td>
                  <td class="px-5 py-3">
                    <% if (ref = secret_source_ref(s)).present? %>
                      <span class="rounded bg-ink-700 px-2 py-0.5 text-xs text-zinc-300"><%= ref %></span>
                    <% else %>
                      <span class="text-zinc-600">—</span>
                    <% end %>
                  </td>
                  <td class="px-5 py-3 whitespace-nowrap">
                    <% if (inj = secret_injection(s)).present? %>
                      <span class="rounded bg-iron-500/10 px-2 py-0.5 text-xs text-iron-300 ring-1 ring-iron-500/25"><%= inj %></span>
                    <% else %>
                      <span class="text-zinc-600">—</span>
                    <% end %>
                  </td>
                  <td class="px-5 py-3 whitespace-nowrap">
                    <span class="rounded bg-ink-700 px-2 py-0.5 text-xs text-zinc-400"><%= s.namespace %></span>
                  </td>
                  <td class="px-5 py-3">
                    <% if s.labels.present? %>
                      <div class="flex flex-wrap gap-1">
                        <% s.labels.each do |k, v| %>
                          <span class="rounded bg-iron-500/10 px-1.5 py-0.5 text-xs text-iron-300/90 ring-1 ring-iron-500/20"><%= k %>=<%= v %></span>
                        <% end %>
                      </div>
                    <% else %>
                      <span class="text-zinc-600">—</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </section>
  <% end %>
</div>
