<% content_for :title, "Secrets · Iron Control" %>

<% total = @secrets_by_kind.values.sum(&:size) %>

<div class="mb-8 flex items-start justify-between gap-4">
  <div>
    <h1 class="text-2xl font-bold text-zinc-100">Secrets</h1>
    <p class="mt-1 text-sm text-zinc-500"><%= pluralize(total, "secret") %> across <%= @secrets_by_kind.size %> kinds.</p>
  </div>

  <div class="relative" data-controller="dropdown">
    <button type="button" data-action="dropdown#toggle" class="btn-primary">
      + Add Secret
    </button>
    <div data-dropdown-target="menu" hidden
         class="absolute right-0 z-20 mt-2 w-48 overflow-hidden rounded-lg border border-ink-600 bg-ink-850 shadow-xl">
      <% secret_form_kinds.each do |_slug, cfg| %>
        <a href="<%= new_polymorphic_path([ :console, cfg[:model].new ]) %>"
           class="block px-4 py-2 text-sm text-zinc-300 transition-colors hover:bg-iron-500/[0.08] hover:text-iron-300"><%= cfg[:label] %></a>
      <% end %>
    </div>
  </div>
</div>

<div class="space-y-10">
  <% @secrets_by_kind.each do |kind, records| %>
    <section>
      <div class="mb-3 flex items-center gap-3">
        <h2 class="text-sm font-semibold text-zinc-200"><%= secret_kind_label(kind) %></h2>
        <span class="rounded-full bg-ink-700 px-2 py-0.5 text-xs text-zinc-400"><%= records.size %></span>
      </div>

      <% if records.empty? %>
        <p class="rounded-lg border border-dashed border-ink-600 bg-ink-850/40 px-5 py-6 text-sm text-zinc-600">No <%= secret_kind_label(kind).downcase %> secrets.</p>
      <% else %>
        <div class="overflow-x-auto rounded-xl border border-ink-600 bg-ink-850/60">
          <table class="min-w-full divide-y divide-ink-600 text-sm">
            <thead class="bg-ink-800/80 text-left text-xs uppercase tracking-wider text-zinc-500">
              <tr>
                <th class="px-5 py-3 font-medium">ID</th>
                <th class="px-5 py-3 font-medium">Name</th>
                <th class="px-5 py-3 font-medium">Source</th>
                <th class="px-5 py-3 font-medium">Labels</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-ink-700">
              <% records.each do |s| %>
                <tr class="align-middle transition-colors hover:bg-iron-500/[0.06]">
                  <td class="px-5 py-3 whitespace-nowrap">
                    <% if s.foreign_id.present? %>
                      <%= link_to truncate_middle(s.foreign_id), console_secret_path(kind, s.oid), class: "text-iron-400 hover:text-iron-300 hover:underline", title: s.foreign_id %>
                      <%= id_meta_line(s.namespace, oid: s.oid) %>
                    <% else %>
                      <%= link_to s.oid, console_secret_path(kind, s.oid), class: "text-iron-400 hover:text-iron-300 hover:underline" %>
                      <%= id_meta_line(s.namespace) %>
                    <% end %>
                  </td>
                  <td class="px-5 py-3 whitespace-nowrap">
                    <% name = s.try(:name).presence %>
                    <% if name %>
                      <span class="text-zinc-100" title="<%= name %>"><%= truncate_middle(name) %></span>
                    <% else %>
                      <span class="text-zinc-600">unnamed</span>
                    <% end %>
                  </td>
                  <td class="px-5 py-3 whitespace-nowrap">
                    <% types = secret_source_types(s) %>
                    <% if types.any? %>
                      <div class="flex gap-1">
                        <% types.each do |type| %>
                          <span class="rounded bg-ink-700 px-2 py-0.5 text-[11px] uppercase tracking-wide text-zinc-300"><%= type %></span>
                        <% end %>
                      </div>
                    <% else %>
                      <span class="text-zinc-600">—</span>
                    <% end %>
                  </td>
                  <td class="px-5 py-3">
                    <% if s.labels.present? %>
                      <div class="flex flex-wrap gap-1">
                        <% s.labels.each do |k, v| %>
                          <span class="rounded bg-iron-500/10 px-1.5 py-0.5 text-xs text-iron-300/90 ring-1 ring-iron-500/20"><%= k %>=<%= v %></span>
                        <% end %>
                      </div>
                    <% else %>
                      <span class="text-zinc-600">—</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </section>
  <% end %>
</div>
