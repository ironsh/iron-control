<% title = @secret.try(:name).presence || @secret.foreign_id.presence || @secret.oid %>
<% content_for :title, "#{title} · Iron Control" %>

<div class="mb-8">
  <a href="<%= console_secrets_path %>" class="text-xs text-zinc-500 hover:text-iron-400">← back to secrets</a>
  <div class="mt-2 flex flex-wrap items-center gap-3">
    <h1 class="text-2xl font-bold text-zinc-100"><%= title %></h1>
    <span class="rounded-md bg-iron-500/10 px-2 py-0.5 text-xs font-medium text-iron-300 ring-1 ring-iron-500/25"><%= secret_kind_label(@kind) %></span>
    <% if secret_form_kinds.key?(@kind) %>
      <a href="<%= edit_polymorphic_path([ :console, @secret ]) %>" class="btn-secondary ml-auto">Edit</a>
    <% end %>
  </div>
  <div class="mt-2 flex flex-wrap items-center gap-2 text-sm">
    <span class="text-iron-400 glow"><%= @secret.oid %></span>
    <span class="text-zinc-600">·</span>
    <span class="rounded bg-ink-700 px-2 py-0.5 text-xs text-zinc-400"><%= @secret.namespace %></span>
    <% if @secret.foreign_id.present? %>
      <span class="text-zinc-600">·</span>
      <span class="text-zinc-400">foreign_id: <span class="break-all text-zinc-200"><%= @secret.foreign_id %></span></span>
    <% end %>
  </div>
  <% if @secret.try(:description).present? %>
    <p class="mt-3 max-w-2xl text-sm text-zinc-500"><%= @secret.description %></p>
  <% end %>
  <% if @secret.labels.present? %>
    <div class="mt-3 flex flex-wrap gap-1">
      <% @secret.labels.each do |k, v| %>
        <span class="rounded bg-iron-500/10 px-1.5 py-0.5 text-xs text-iron-300/90 ring-1 ring-iron-500/20"><%= k %>=<%= v %></span>
      <% end %>
    </div>
  <% end %>
</div>

<!-- Sources -->
<section class="mb-8">
  <h2 class="mb-3 text-xs font-semibold uppercase tracking-wider text-zinc-500">Sources</h2>
  <% segments = secret_source_segments(@secret) %>
  <% if segments.any? %>
    <div class="overflow-hidden rounded-xl border border-ink-600 bg-ink-850/60">
      <table class="min-w-full divide-y divide-ink-600 text-sm">
        <thead class="bg-ink-800/80 text-left text-xs uppercase tracking-wider text-zinc-500">
          <tr>
            <% if segments.any? { |seg| seg[:role].present? } %>
              <th class="px-5 py-3 font-medium">Field</th>
            <% end %>
            <th class="px-5 py-3 font-medium">Backend</th>
            <th class="px-5 py-3 font-medium">Reference</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-ink-700">
          <% has_roles = segments.any? { |seg| seg[:role].present? } %>
          <% segments.each do |seg| %>
            <tr class="align-top">
              <% if has_roles %>
                <td class="px-5 py-3 whitespace-nowrap font-mono text-xs text-zinc-400"><%= seg[:role] || "—" %></td>
              <% end %>
              <td class="px-5 py-3 whitespace-nowrap">
                <span class="rounded bg-ink-700 px-2 py-0.5 text-xs text-zinc-300"><%= source_type_label(seg[:type]) %></span>
              </td>
              <td class="px-5 py-3">
                <% if seg[:ref].present? %>
                  <span class="block break-all font-mono text-xs text-zinc-300"><%= seg[:ref] %></span>
                <% else %>
                  <span class="text-zinc-600">—</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="rounded-lg border border-dashed border-ink-600 bg-ink-850/40 px-5 py-6 text-sm text-zinc-600">No source configured.</p>
  <% end %>
</section>

<!-- Configuration -->
<%
  rows = []
  if (inj = secret_injection(@secret)).present?
    rows << [ "Injects into", inj ]
  end
  case @secret
  when StaticSecret
    rows << [ "Mode", @secret.replace_config.present? ? "replace" : "inject" ]
  when GcpAuthSecret
    rows << [ "Subject", @secret.subject ] if @secret.subject.present?
    rows << [ "Scopes", Array(@secret.scopes).join("\n") ] if @secret.scopes.present?
  when AwsAuthSecret
    rows << [ "Allowed regions", Array(@secret.allowed_regions).join("\n") ] if @secret.allowed_regions.present?
    rows << [ "Allowed services", Array(@secret.allowed_services).join("\n") ] if @secret.allowed_services.present?
  when OauthTokenSecret
    rows << [ "Grant", @secret.grant ]
    rows << [ "Token endpoint", @secret.token_endpoint ]
    rows << [ "Audience", @secret.audience ] if @secret.audience.present?
    rows << [ "Scopes", Array(@secret.scopes).join("\n") ] if @secret.scopes.present?
  when PgDsnSecret
    rows << [ "Database", @secret.database ] if @secret.database.present?
    rows << [ "Role", @secret.role ] if @secret.role.present?
    if @secret.settings.present?
      rows << [ "Session settings", @secret.settings.map { |s| "#{s["name"]} = #{s["value"]}" }.join("\n") ]
    end
  when HmacSecret
    rows << [ "Timestamp format", @secret.timestamp_format ]
    rows << [ "Algorithm", @secret.signature_algorithm ]
    rows << [ "Key encoding", @secret.signature_key_encoding ]
    rows << [ "Output encoding", @secret.signature_output_encoding ]
    rows << [ "Message", @secret.signature_message ]
  end
%>
<% if rows.any? %>
  <section class="mb-8">
    <h2 class="mb-3 text-xs font-semibold uppercase tracking-wider text-zinc-500">Configuration</h2>
    <dl class="overflow-hidden rounded-xl border border-ink-600 bg-ink-850/60 divide-y divide-ink-700">
      <% rows.each do |label, value| %>
        <div class="flex flex-col gap-1 px-5 py-3 sm:flex-row sm:gap-4">
          <dt class="w-40 shrink-0 text-xs uppercase tracking-wider text-zinc-500"><%= label %></dt>
          <dd class="whitespace-pre-line break-all font-mono text-xs text-zinc-200"><%= value %></dd>
        </div>
      <% end %>
    </dl>
  </section>
<% end %>

<!-- HMAC signed headers -->
<% if @secret.is_a?(HmacSecret) && @secret.headers.present? %>
  <section class="mb-8">
    <h2 class="mb-3 text-xs font-semibold uppercase tracking-wider text-zinc-500">Signed Headers</h2>
    <div class="overflow-hidden rounded-xl border border-ink-600 bg-ink-850/60">
      <table class="min-w-full divide-y divide-ink-600 text-sm">
        <thead class="bg-ink-800/80 text-left text-xs uppercase tracking-wider text-zinc-500">
          <tr><th class="px-5 py-3 font-medium">Name</th><th class="px-5 py-3 font-medium">Value</th></tr>
        </thead>
        <tbody class="divide-y divide-ink-700">
          <% @secret.headers.each do |h| %>
            <tr class="align-top">
              <td class="px-5 py-3 whitespace-nowrap font-mono text-xs text-zinc-300"><%= h["name"] %></td>
              <td class="px-5 py-3 break-all font-mono text-xs text-zinc-400"><%= h["value"] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
<% end %>

<!-- Request rules -->
<% if @secret.respond_to?(:rules) %>
  <section class="mb-8">
    <h2 class="mb-3 text-xs font-semibold uppercase tracking-wider text-zinc-500">Request Rules</h2>
    <% rules = @secret.rules %>
    <% if rules.any? %>
      <div class="overflow-hidden rounded-xl border border-ink-600 bg-ink-850/60">
        <table class="min-w-full divide-y divide-ink-600 text-sm">
          <thead class="bg-ink-800/80 text-left text-xs uppercase tracking-wider text-zinc-500">
            <tr>
              <th class="px-5 py-3 font-medium">Match</th>
              <th class="px-5 py-3 font-medium">Methods</th>
              <th class="px-5 py-3 font-medium">Paths</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-ink-700">
            <% rules.each do |r| %>
              <tr class="align-top">
                <td class="px-5 py-3 font-mono text-xs text-zinc-300">
                  <%= r.host.presence ? "host: #{r.host}" : "cidr: #{r.cidr}" %>
                </td>
                <td class="px-5 py-3 font-mono text-xs text-zinc-400"><%= Array(r.http_methods).presence&.join(", ") || "any" %></td>
                <td class="px-5 py-3 break-all font-mono text-xs text-zinc-400"><%= Array(r.paths).presence&.join(", ") || "any" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-sm text-zinc-600">No request rules.</p>
    <% end %>
  </section>
<% end %>
