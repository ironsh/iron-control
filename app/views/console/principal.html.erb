<% content_for :title, "#{@principal.name || @principal.foreign_id || @principal.oid} · Iron Control" %>

<div class="mb-8">
  <a href="<%= console_principals_path %>" class="text-xs text-zinc-500 hover:text-iron-400">← back to principals</a>
  <h1 class="mt-2 text-2xl font-bold text-zinc-100">
    <%= @principal.name.presence || @principal.foreign_id.presence || "Principal" %>
  </h1>
  <div class="mt-2 flex flex-wrap items-center gap-2 text-sm">
    <span class="text-iron-400 glow"><%= @principal.oid %></span>
    <span class="text-zinc-600">·</span>
    <span class="rounded bg-ink-700 px-2 py-0.5 text-xs text-zinc-400"><%= @principal.namespace %></span>
    <% if @principal.foreign_id.present? %>
      <span class="text-zinc-600">·</span>
      <span class="text-zinc-400">foreign_id: <span class="text-zinc-200"><%= @principal.foreign_id %></span></span>
    <% end %>
  </div>
  <% if @principal.labels.present? %>
    <div class="mt-3 flex flex-wrap gap-1">
      <% @principal.labels.each do |k, v| %>
        <span class="rounded bg-iron-500/10 px-1.5 py-0.5 text-xs text-iron-300/90 ring-1 ring-iron-500/20"><%= k %>=<%= v %></span>
      <% end %>
    </div>
  <% end %>
</div>

<!-- Roles -->
<section class="mb-8">
  <h2 class="mb-3 text-xs font-semibold uppercase tracking-wider text-zinc-500">Assigned Roles</h2>
  <% if @roles.any? %>
    <div class="flex flex-wrap gap-2">
      <% @roles.each do |r| %>
        <span class="inline-flex items-center gap-2 rounded-lg border border-ink-600 bg-ink-800 px-3 py-1.5 text-sm">
          <span class="text-iron-400"><%= r.oid %></span>
          <span class="text-zinc-300"><%= r.name.presence || r.foreign_id %></span>
        </span>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-zinc-600">No roles assigned.</p>
  <% end %>
</section>

<!-- Effective grants -->
<section>
  <h2 class="mb-1 text-xs font-semibold uppercase tracking-wider text-zinc-500">Effective Grants</h2>
  <p class="mb-4 text-sm text-zinc-500">Every secret this principal resolves to: direct grants plus grants inherited from its roles.</p>

  <% total = @granted.values.sum(&:size) %>
  <% if total.zero? %>
    <div class="rounded-xl border border-dashed border-ink-600 bg-ink-850/40 px-5 py-10 text-center text-zinc-600">
      This principal has no effective grants.
    </div>
  <% else %>
    <div class="overflow-hidden rounded-xl border border-ink-600 bg-ink-850/60">
      <table class="min-w-full divide-y divide-ink-600 text-sm">
        <thead class="bg-ink-800/80 text-left text-xs uppercase tracking-wider text-zinc-500">
          <tr>
            <th class="px-5 py-3 font-medium">Type</th>
            <th class="px-5 py-3 font-medium">ID</th>
            <th class="px-5 py-3 font-medium">Foreign ID</th>
            <th class="px-5 py-3 font-medium">Name</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-ink-700">
          <% @granted.each do |kind, records| %>
            <% records.each do |s| %>
              <tr class="transition-colors hover:bg-iron-500/[0.06]">
                <td class="px-5 py-3 whitespace-nowrap">
                  <span class="rounded-md bg-iron-500/10 px-2 py-0.5 text-xs font-medium text-iron-300 ring-1 ring-iron-500/25"><%= secret_kind_label(kind) %></span>
                </td>
                <td class="px-5 py-3 whitespace-nowrap text-iron-400"><%= s.oid %></td>
                <td class="px-5 py-3 whitespace-nowrap text-zinc-300"><%= s.foreign_id || "—" %></td>
                <td class="px-5 py-3 whitespace-nowrap text-zinc-100"><%= s.try(:name).presence || %(<span class="text-zinc-600">unnamed</span>).html_safe %></td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</section>
