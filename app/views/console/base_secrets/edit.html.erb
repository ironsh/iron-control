<% title = @secret.try(:name).presence || @secret.foreign_id.presence || @secret.oid %>
<% content_for :title, "Edit #{title} · Iron Control" %>

<div class="mb-8">
  <a href="<%= console_secret_path(@kind, @secret.oid) %>" class="text-xs text-zinc-500 hover:text-iron-400">← back to secret</a>
  <div class="mt-2 flex flex-wrap items-center gap-3">
    <h1 class="text-2xl font-bold text-zinc-100">Edit <%= title %></h1>
    <span class="rounded-md bg-iron-500/10 px-2 py-0.5 text-xs font-medium text-iron-300 ring-1 ring-iron-500/25"><%= secret_kind_label(@kind) %></span>
  </div>
</div>

<%= render "errors", secret: @secret %>
<%= render "form_#{@kind}", secret: @secret %>
