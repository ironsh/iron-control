<% content_for :title, "Credentials · Iron Control" %>

<div class="mb-8">
  <h1 class="text-2xl font-bold text-zinc-100">Managed Credentials</h1>
  <p class="mt-1 text-sm text-zinc-500"><%= pluralize(@credentials.size, "broker credential") %>. Token material is never shown.</p>
</div>

<% if @credentials.empty? %>
  <p class="rounded-lg border border-dashed border-ink-600 bg-ink-850/40 px-5 py-6 text-sm text-zinc-600">No managed credentials.</p>
<% else %>
  <div class="overflow-hidden rounded-xl border border-ink-600 bg-ink-850/60">
    <table class="min-w-full divide-y divide-ink-600 text-sm">
      <thead class="bg-ink-800/80 text-left text-xs uppercase tracking-wider text-zinc-500">
        <tr>
          <th class="px-5 py-3 font-medium">ID</th>
          <th class="px-5 py-3 font-medium">Foreign ID</th>
          <th class="px-5 py-3 font-medium">Name</th>
          <th class="px-5 py-3 font-medium">Status</th>
          <th class="px-5 py-3 font-medium">Token Endpoint</th>
          <th class="px-5 py-3 font-medium">Expires</th>
          <th class="px-5 py-3 font-medium">Last Refresh</th>
          <th class="px-5 py-3 font-medium">Next Attempt</th>
          <th class="px-5 py-3 font-medium">Namespace</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-ink-700">
        <% @credentials.each do |c| %>
          <tr class="transition-colors hover:bg-iron-500/[0.06]">
            <td class="px-5 py-3 whitespace-nowrap text-iron-400"><%= c.oid %></td>
            <td class="px-5 py-3 whitespace-nowrap text-zinc-300"><%= c.foreign_id || "—" %></td>
            <td class="px-5 py-3 whitespace-nowrap text-zinc-100"><%= c.name.presence || %(<span class="text-zinc-600">unnamed</span>).html_safe %></td>
            <td class="px-5 py-3 whitespace-nowrap">
              <%
                badge = case c.status
                        when "live" then "bg-emerald-500/10 text-emerald-300 ring-emerald-500/25"
                        when "dead" then "bg-red-500/10 text-red-300 ring-red-500/25"
                        else "bg-amber-500/10 text-amber-300 ring-amber-500/25"
                        end
              %>
              <span class="rounded px-2 py-0.5 text-xs ring-1 <%= badge %>"><%= c.status %></span>
              <% if c.status == "dead" && c.dead_reason.present? %>
                <span class="ml-1 text-xs text-zinc-500"><%= c.dead_reason %></span>
              <% end %>
            </td>
            <td class="px-5 py-3 whitespace-nowrap text-zinc-400"><%= c.token_endpoint %></td>
            <td class="px-5 py-3 whitespace-nowrap text-zinc-400"><%= c.expires_at ? c.expires_at.utc.iso8601 : "—" %></td>
            <td class="px-5 py-3 whitespace-nowrap text-zinc-400"><%= c.last_refresh ? c.last_refresh.utc.iso8601 : "—" %></td>
            <td class="px-5 py-3 whitespace-nowrap text-zinc-400"><%= c.next_attempt_at ? c.next_attempt_at.utc.iso8601 : "—" %></td>
            <td class="px-5 py-3 whitespace-nowrap">
              <span class="rounded bg-ink-700 px-2 py-0.5 text-xs text-zinc-400"><%= c.namespace %></span>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
