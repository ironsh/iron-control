<% content_for :title, "OAuth Apps · Iron Control" %>

<div class="mb-8 flex items-start justify-between gap-4">
  <div>
    <h1 class="text-2xl font-bold text-zinc-100">OAuth Apps</h1>
    <p class="mt-1 text-sm text-zinc-500"><%= pluralize(@oauth_apps.size, "OAuth app") %> driving the public consent flow.</p>
  </div>
  <a href="<%= new_console_oauth_app_form_path %>" class="btn-primary">+ Add OAuth App</a>
</div>

<% if @oauth_apps.empty? %>
  <p class="rounded-lg border border-dashed border-ink-600 bg-ink-850/40 px-5 py-6 text-sm text-zinc-600">No OAuth apps.</p>
<% else %>
  <div class="overflow-x-auto rounded-xl border border-ink-600 bg-ink-850/60">
    <table class="min-w-full divide-y divide-ink-600 text-sm">
      <thead class="bg-ink-800/80 text-left text-xs uppercase tracking-wider text-zinc-500">
        <tr>
          <th class="px-5 py-3 font-medium">ID</th>
          <th class="px-5 py-3 font-medium">Name</th>
          <th class="px-5 py-3 font-medium">Provider</th>
          <th class="px-5 py-3 font-medium">Slug</th>
          <th class="px-5 py-3 font-medium">Client ID</th>
          <th class="px-5 py-3 font-medium">Enabled</th>
          <th class="px-5 py-3 font-medium">Credentials</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-ink-700">
        <% @oauth_apps.each do |a| %>
          <tr class="transition-colors hover:bg-iron-500/[0.06]">
            <td class="px-5 py-3 whitespace-nowrap">
              <% if a.foreign_id.present? %>
                <%= link_to truncate_middle(a.foreign_id), console_oauth_app_path(a.oid), class: "text-iron-400 hover:text-iron-300 hover:underline", title: a.foreign_id %>
                <%= id_meta_line(a.namespace, oid: a.oid) %>
              <% else %>
                <%= link_to a.oid, console_oauth_app_path(a.oid), class: "text-iron-400 hover:text-iron-300 hover:underline" %>
                <%= id_meta_line(a.namespace) %>
              <% end %>
            </td>
            <td class="px-5 py-3 whitespace-nowrap text-zinc-100">
              <% if a.name.presence %>
                <span title="<%= a.name %>"><%= truncate_middle(a.name) %></span>
              <% else %>
                <span class="text-zinc-600">unnamed</span>
              <% end %>
            </td>
            <td class="px-5 py-3 whitespace-nowrap">
              <span class="rounded bg-ink-700 px-2 py-0.5 text-[11px] uppercase tracking-wide text-zinc-300"><%= a.provider %></span>
            </td>
            <td class="px-5 py-3 whitespace-nowrap font-mono text-xs text-zinc-300"><%= a.slug %></td>
            <td class="px-5 py-3 whitespace-nowrap text-zinc-400"><%= truncate_middle(a.client_id) %></td>
            <td class="px-5 py-3 whitespace-nowrap">
              <% if a.enabled? %>
                <span class="rounded px-2 py-0.5 text-xs ring-1 bg-emerald-500/10 text-emerald-300 ring-emerald-500/25">enabled</span>
              <% else %>
                <span class="rounded px-2 py-0.5 text-xs ring-1 bg-zinc-500/10 text-zinc-400 ring-zinc-500/25">disabled</span>
              <% end %>
            </td>
            <td class="px-5 py-3 whitespace-nowrap text-zinc-400"><%= a.broker_credentials.count %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
