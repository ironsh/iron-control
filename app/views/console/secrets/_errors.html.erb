<%#
  Renders the secret's validation errors. Nested source/rule records are saved via
  autosave, which adds only a generic "is invalid" on the parent; we drop those and
  surface the children's own detailed messages instead.
%>
<%
  nested_attrs = %i[source dsn_source rules]
  base_messages = secret.errors.reject { |e| nested_attrs.include?(e.attribute) }.map(&:full_message)

  nested_messages = []
  %i[source dsn_source].each do |assoc|
    next unless secret.respond_to?(assoc)
    child = secret.public_send(assoc)
    next unless child&.errors&.any?
    child.errors.full_messages.each { |m| nested_messages << "Source: #{m}" }
  end
  if secret.respond_to?(:rules)
    secret.rules.each_with_index do |rule, i|
      rule.errors.full_messages.each { |m| nested_messages << "Rule #{i + 1}: #{m}" }
    end
  end

  messages = base_messages + nested_messages
%>
<% if messages.any? %>
  <div class="mb-6 rounded border border-red-500/40 bg-red-500/[0.08] px-4 py-3 text-sm text-red-300">
    <p class="mb-1 font-semibold"><%= pluralize(messages.size, "error") %> prevented this secret from saving:</p>
    <ul class="list-disc space-y-0.5 pl-5">
      <% messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>
