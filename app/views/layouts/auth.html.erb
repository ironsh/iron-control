<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <title><%= content_for(:title) || "Iron Control" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="utf-8">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">

    <%# Tailwind is compiled by the standalone binary into app/assets/builds/tailwind.css.
        See config/tailwind.config.js for the iron/ink palette and radii overrides. %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">

    <style>
      ::selection { background: #ff5b04; color: #08090c; }
    </style>
  </head>

  <body class="h-full bg-ink-900 text-zinc-300 font-mono antialiased">
    <main class="flex min-h-full items-center justify-center px-6 py-16">
      <div class="w-full max-w-sm">
        <%= yield %>
      </div>
    </main>
  </body>
</html>
